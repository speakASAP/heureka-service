generator client {
  provider      = "prisma-client-js"
  output        = "../shared/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

generator client_default {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Heureka Account - Heureka platform account credentials
model HeurekaAccount {
  id        String         @id @default(uuid()) @db.Uuid
  name      String         @db.VarChar(200)
  apiKey    String?        @db.Text
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now()) @db.Timestamp(6)
  updatedAt DateTime       @updatedAt @db.Timestamp(6)
  offers    HeurekaOffer[]
  orders    HeurekaOrder[]

  @@index([isActive])
  @@map("heureka_accounts")
}

// Heureka Offer - Heureka product listings
model HeurekaOffer {
  id            String         @id @default(uuid()) @db.Uuid
  accountId     String         @db.Uuid
  productId     String?        @db.Uuid
  title         String?        @db.VarChar(500)
  price         Decimal?       @db.Decimal(10, 2)
  stockQuantity Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now()) @db.Timestamp(6)
  updatedAt     DateTime       @updatedAt @db.Timestamp(6)
  account       HeurekaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([productId])
  @@index([isActive])
  @@map("heureka_offers")
}

// Heureka Order - Orders received from Heureka
model HeurekaOrder {
  id              String         @id @default(uuid()) @db.Uuid
  accountId       String         @db.Uuid
  heurekaOrderId  String?        @db.VarChar(100)
  orderId         String?        @db.Uuid
  customerEmail   String?        @db.VarChar(200)
  customerPhone   String?        @db.VarChar(50)
  total           Decimal        @db.Decimal(10, 2) @default(0)
  currency        String         @db.VarChar(10) @default("CZK")
  status          String         @db.VarChar(50) @default("pending")
  forwarded       Boolean        @default(false)
  createdAt       DateTime       @default(now()) @db.Timestamp(6)
  updatedAt       DateTime       @updatedAt @db.Timestamp(6)
  account         HeurekaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([heurekaOrderId])
  @@index([status])
  @@index([forwarded])
  @@map("heureka_orders")
}

// Heureka Feed - Feed generation history
model HeurekaFeed {
  id            String           @id @default(uuid()) @db.Uuid
  feedType      String           @db.VarChar(50) // heureka_cz, heureka_sk
  feedUrl       String?          @db.VarChar(1000)
  productCount  Int              @default(0)
  status        String           @db.VarChar(50) // pending, generating, completed, failed
  generatedAt   DateTime?
  createdAt     DateTime         @default(now()) @db.Timestamp(6)
  updatedAt     DateTime         @updatedAt @db.Timestamp(6)

  @@index([feedType])
  @@index([status])
  @@map("heureka_feeds")
}

// Heureka Product - Products included in feed (linked to catalog)
model HeurekaProduct {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid // Catalog product ID (no FK - references catalog-microservice)
  isIncluded Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  @@unique([productId])
  @@index([isIncluded])
  @@map("heureka_products")
}

// Heureka Settings - Feed configuration
model HeurekaSettings {
  id            String   @id @default(uuid()) @db.Uuid
  feedType      String   @unique @db.VarChar(50) // heureka_cz, heureka_sk
  shopName      String   @db.VarChar(200)
  shopUrl       String   @db.VarChar(500)
  contactEmail  String   @db.VarChar(200)
  contactPhone  String?  @db.VarChar(50)
  deliveryDays  Int      @default(5)
  deliveryPrice Decimal? @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(10, 2)
  currency      String   @default("CZK") @db.VarChar(3)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @db.Timestamp(6)

  @@index([feedType])
  @@index([isActive])
  @@map("heureka_settings")
}


// Heureka Operation Event - append-only durable operation evidence
model HeurekaOperationEvent {
  id              String   @id @default(uuid()) @db.Uuid
  feedType        String?  @map("feed_type") @db.VarChar(50)
  accountId       String?  @map("account_id") @db.Uuid
  action          String   @db.VarChar(120)
  status          String?  @db.VarChar(50)
  idempotencyKey  String?  @unique @map("idempotency_key") @db.VarChar(160)
  actorId         String?  @map("actor_id") @db.VarChar(120)
  entityType      String?  @map("entity_type") @db.VarChar(80)
  entityId        String?  @map("entity_id") @db.VarChar(120)
  productId       String?  @map("product_id") @db.Uuid
  externalId      String?  @map("external_id") @db.VarChar(160)
  correlationId   String?  @map("correlation_id") @db.VarChar(120)
  payloadHash     String?  @map("payload_hash") @db.VarChar(128)
  requestSummary  Json?    @map("request_summary")
  responseSummary Json?    @map("response_summary")
  policySnapshot  Json?    @map("policy_snapshot")
  blockedReasons  Json?    @map("blocked_reasons")
  errorSummary    String?  @map("error_summary") @db.VarChar(1000)
  redactedContext Json?    @map("redacted_context")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([action])
  @@index([status])
  @@index([feedType])
  @@index([accountId])
  @@index([productId])
  @@index([entityType, entityId])
  @@index([externalId])
  @@index([correlationId])
  @@index([createdAt])
  @@map("heureka_operation_events")
}
